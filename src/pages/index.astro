---
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Vaughn Aldredge — Product & Growth Designer</title>
  </head>
  <body>

    <div class="page-container">
      <nav class="site-nav">
        <span>Vaughn Aldredge</span>
        <ul class="site-nav__links">
          <li><a href="/about" class="site-nav__link">about</a></li>
          <li><a href="/resume" class="site-nav__link">resume</a></li>
        </ul>
      </nav>
    </div>

    <hr class="section-divider" />

    <div class="page-container">
      <div class="home-hero">
        <div class="home-hero__photo" style="background-color: var(--color-neutral-60);"></div>
        <div>
          <h1 class="home-hero__name">Hi, I'm Vaughn 👋</h1>
          <p class="home-hero__bio">I'm a <strong>product & growth designer</strong> with 20+ years of experience. I lead cross-functional teams, turning complex problems into engaging, impactful digital experiences.</p>
        </div>
      </div>
    </div>

    <hr class="section-divider" />

    <div class="page-container">
      <section class="section">

        <h2 class="home-section-label">Growth</h2>
        <div class="project-grid">

          <div>
            <a class="project-card project-card--plunk-trust" href="/plunk-trust">
              <p class="project-card__title">Driving adoption with trust</p>
              <p class="project-card__desc">Trust-building features that increased enterprise sales 4.5x and helped Plunk raise $12M seed.</p>
              <div class="card-visual">
                <img src="/plunk-trust-before.svg" class="card-visual__before" alt="" aria-hidden="true" />
                <img src="/plunk-trust-after.svg" class="card-visual__after" alt="" aria-hidden="true" />
              </div>
            </a>
            <div class="project-card__tags" style="margin-top: 0.375rem; gap: 8px;">
              <span class="tag-chip">#growthdesign</span>
              <span class="tag-chip">#productdesign</span>
              <span class="tag-chip">#monetization</span>
            </div>
          </div>

          <div>
            <a class="project-card project-card--plunk-onboarding" href="/plunk-onboarding">
              <p class="project-card__title">Boosting registrations with onboarding tests</p>
              <p class="project-card__desc">An onboarding redesign guided users into early engagement — boosting registrations 3x and retention 2x.</p>
            </a>
            <div class="project-card__tags" style="margin-top: 0.375rem; gap: 8px;">
              <span class="tag-chip">#growthdesign</span>
              <span class="tag-chip">#engagement</span>
              <span class="tag-chip">#activation</span>
              <span class="tag-chip">#retention</span>
            </div>
          </div>

        </div>

        <h2 class="home-section-label">Product design</h2>
        <div class="project-grid project-grid--single">

          <div>
            <a class="project-card project-card--here" href="/here">
              <p class="project-card__title" style="max-width: 100%;">Integrating data pipelines into our location services vision</p>
              <p class="project-card__desc" style="max-width: 100%;">How I created the vision for a new data services platform — and built the data processing pipeline application that powered it.</p>
            </a>
            <div class="project-card__tags" style="margin-top: 0.375rem; gap: 8px;">
              <span class="tag-chip">#productdesign</span>
              <span class="tag-chip">#developerservices</span>
              <span class="tag-chip">#developertools</span>
            </div>
          </div>

        </div>

      </section>
    </div>

    <hr class="section-divider" />

    <div class="page-container">
      <nav class="site-nav">
        <span>Vaughn Aldredge</span>
        <ul class="site-nav__links">
          <li><a href="/about" class="site-nav__link">about</a></li>
          <li><a href="/resume" class="site-nav__link">resume</a></li>
        </ul>
      </nav>
    </div>

  </body>
</html>
